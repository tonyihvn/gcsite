# GINTEC Solutions - Production Environment Configuration
# Copy this to .env on production server and update values

# ============================================================================
# APPLICATION SETTINGS - UPDATE FOR PRODUCTION
# ============================================================================

APP_NAME=GINTEC Solutions Consults Ltd
APP_URL=https://gintec.com.ng
APP_ENV=production
APP_DEBUG=false  # CRITICAL: Never enable debug in production!

# ============================================================================
# SECURITY KEYS - GENERATE NEW RANDOM 32-CHARACTER STRINGS
# ============================================================================

# Generate with: head -c 32 /dev/urandom | base64
APP_KEY=change-me-to-random-32-char-string-for-production
ENCRYPTION_KEY=change-me-to-random-32-char-string-for-production

# ============================================================================
# DATABASE - UPDATE WITH HOSTING PROVIDER CREDENTIALS
# ============================================================================

DB_HOST=localhost
DB_PORT=3306
DB_NAME=gintec_solutions
DB_USER=your_hosting_db_user
DB_PASS=your_hosting_db_password

# ============================================================================
# EMAIL CONFIGURATION - CONFIGURE WITH YOUR HOSTING PROVIDER
# ============================================================================

MAIL_MAILER=smtp
MAIL_HOST=mail.gintec.com.ng
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USER=info@gintec.com.ng
MAIL_PASS=your_email_password
MAIL_FROM=info@gintec.com.ng
MAIL_FROM_NAME=GINTEC Solutions Consults Ltd

# ============================================================================
# ADMIN SETTINGS
# ============================================================================

ADMIN_EMAIL=info@gintec.com.ng
COMPANY_NAME=GINTEC Solutions Consults Ltd
COMPANY_ADDRESS=2nd Floor, Peace Plaza B, Utako, Abuja
COMPANY_PHONE=07067973091
COMPANY_EMAIL=info@gintec.com.ng
COMPANY_WEBSITE=www.gintec.com.ng
CEO_NAME=Anthony Nwokoma

# ============================================================================
# AI CHAT CONFIGURATION (Optional - leave as is if not using)
# ============================================================================

OPENAI_API_KEY=your-openai-key-here
CHAT_BOT_NAME=GINTEC AI Assistant

# ============================================================================
# SESSION & FILE UPLOAD
# ============================================================================

SESSION_TIMEOUT=3600
REMEMBER_ME_DURATION=2592000
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,ppt,pptx,zip,rar

# ============================================================================
# PAYMENT GATEWAY (Optional for future use)
# ============================================================================

PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# ============================================================================
# NOTES FOR PRODUCTION
# ============================================================================
# 
# 1. APP_DEBUG must be FALSE in production
# 2. Generate new APP_KEY and ENCRYPTION_KEY - do not reuse development keys
# 3. Update DB_* with credentials provided by hosting
# 4. Verify MAIL_* credentials with hosting provider's email/SMTP settings
# 5. Never commit .env file to git repository
# 6. Keep .env file secure with proper permissions: chmod 600 .env
# 7. Backup .env file in secure location (not in public folder)
# 8. Test email sending before going live
# 9. Test database connection on first deployment
# 10. Monitor error logs at: /home/gintecadmin/error_log
#
# ============================================================================
