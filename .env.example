# GINTEC Solutions Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gsdb
DB_USER=root
DB_PASS=

# Application Settings
APP_NAME=GINTEC Solutions Consults Ltd
APP_URL=http://localhost/gintec
APP_ENV=development
APP_DEBUG=true

# Security
APP_KEY=your-secret-key-here-min-32-characters
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# Email Configuration
MAIL_MAILER=smtp
MAIL_HOST=mail.gintec.com.ng
MAIL_PORT=465
MAIL_ENCRYPTION=ssl
MAIL_USER=your-email@example.com
MAIL_PASS=your-email-password-here
MAIL_FROM=your-email@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Admin Settings
ADMIN_EMAIL=info@gintec.com.ng
COMPANY_NAME=GINTEC Solutions Consults Ltd
COMPANY_ADDRESS=2nd Floor, Peace Plaza B, Utako, Abuja
COMPANY_PHONE=07067973091
COMPANY_EMAIL=info@gintec.com.ng
COMPANY_WEBSITE=www.gintec.com.ng
CEO_NAME=Anthony Nwokoma

# AI Chat Configuration
OPENAI_API_KEY=your-openai-key-here
CHAT_BOT_NAME=GINTEC AI Assistant

# Session Configuration
SESSION_TIMEOUT=3600
REMEMBER_ME_DURATION=2592000

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,ppt,pptx,zip,rar

# Payment Gateway (Optional for future)
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key
